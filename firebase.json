{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "functions",
      "node_modules",
      ".git",
      ".claude",
      "CLAUDE_CODE_CONTEXT.md",
      "LICENSE",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/stats", "destination": "/stats.html" },
      { "source": "/play", "destination": "/play.html" }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22"
  }
}
