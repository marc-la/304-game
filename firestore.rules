rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lobbies: readable by anyone (to check if a code exists), writable only by Cloud Functions
    match /lobbies/{code} {
      allow read: if true;
      allow write: if false;

      // Game documents: not readable by clients — contains all hands
      match /games/{gameId} {
        allow read, write: if false;

        // Player views: readable only by the player assigned to that seat
        match /playerViews/{seatId} {
          allow read: if isPlayerInSeat(code, seatId);
          allow write: if false;
        }
      }
    }

    function isPlayerInSeat(code, seatId) {
      let lobby = get(/databases/$(database)/documents/lobbies/$(code));
      return request.auth != null
        && lobby.data.seats[seatId] != null
        && lobby.data.seats[seatId].uid == request.auth.uid;
    }
  }
}
